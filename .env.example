# Copy to `.env` (which is gitignored) and fill in your secrets.
# `rankevolve run` auto-loads `.env` from the config's directory and
# then walks up to the repo root, seeding env-vars BEFORE ${...} interpolation
# in the YAML config. Vars already set in your shell take precedence.

# Required for proposer.kind=openai_chat
OPENAI_API_KEY=sk-...

# Required for proposer.kind=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible alternates (uncomment & set api_base in the YAML):
# OPENROUTER_API_KEY=...
# TOGETHER_API_KEY=...

# evaluator_parallel.py reads this; an empty string means "evaluate every
# dataset" (~1-2 hours per program). Set the fast subset for short runs:
EVAL_EXCLUDE_DATASETS=dl19,dl20,fever,climate-fever,hotpotqa,dbpedia-entity,nq,quora,webis-touche2020,cqadupstack,leetcode,aops,theoremqa_questions,robotics,psychology,sustainable_living
